rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media queue uploads - herkes okuyabilir, sadece authenticated yazabilir
    match /media-queue/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null || true; // Development için açık
    }

    // Temp uploads - geçici dosyalar
    match /temp/{allPaths=**} {
      allow read, write: if true; // Development için açık
    }

    // Orchestrator assets - ürün, aksesuar, mobilya görselleri
    match /orchestrator-assets/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Development için açık
    }

    // Enhancement originals, results & references - fotoğraf iyileştirme görselleri
    match /enhancement-originals/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Admin panel'den yüklenir
    }
    match /enhancement-results/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Cloud Functions yazabilir
    }
    match /enhancement-references/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Admin panel'den preset referans görselleri yüklenir
    }

    // Generated images - AI tarafından üretilen görseller
    match /generated/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Cloud Functions yazabilir
    }

    // Landing page hero görselleri
    match /landing/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Admin panel'den yüklenir
    }
  }
}
